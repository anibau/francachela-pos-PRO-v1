# 🍻 Francachela POS Backend - Variables de Entorno

# 🗄️ Base de Datos PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=francachela_pos

# 🔐 JWT Configuration
JWT_SECRET=tu_jwt_secret_super_seguro_aqui_cambiar_en_produccion
JWT_EXPIRES_IN=24h

# 🌐 Servidor
PORT=3000
NODE_ENV=development

# 📱 WhatsApp (Opcional - para notificaciones automáticas)
WHATSAPP_ENABLED=true
WHATSAPP_SESSION_NAME=francachela-session

# 📊 Excel Export (Configuración opcional)
EXCEL_TEMP_DIR=./temp/excel
EXCEL_MAX_ROWS=10000

# 🔧 Configuraciones adicionales
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
API_PREFIX=api
SWAGGER_ENABLED=true

# 📧 Email (Para futuras notificaciones)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_password_de_aplicacion

# 🚀 Configuraciones de Producción
# DATABASE_SSL=true
# DATABASE_SYNCHRONIZE=false
# LOG_LEVEL=error

