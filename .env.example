# =================================
# FRANCACHELA POS - BACKEND CONFIG
# =================================

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=tu_password_aqui
DB_DATABASE=francachela_pos

# JWT Configuration
JWT_SECRET=tu_jwt_secret_muy_seguro_aqui_cambiar_en_produccion
JWT_EXPIRES_IN=1h

# Aplicación
PORT=3000
NODE_ENV=development

# CORS Origins (separados por coma)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Baileys WhatsApp Integration (Opcional)
BAILEYS_SESSION_PATH=./sessions
BAILEYS_WEBHOOK_URL=http://localhost:3000/webhook
BAILEYS_ENABLED=false

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# Logging
LOG_LEVEL=debug

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DEST=./uploads

# Email Configuration (Opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_password_email
SMTP_FROM=noreply@francachela.com

# Redis (Opcional para cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

